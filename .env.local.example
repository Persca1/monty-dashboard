# Kopieer dit bestand naar .env.local en vul je eigen waarden in.
# .env.local wordt NOOIT gecommit (zie .gitignore).

# Supabase project URL (zonder /rest/v1 en zonder slash op het einde)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase service_role sleutel — UITSLUITEND server-side, nooit in de browser
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# Anthropic API-sleutel — alleen voor de Copywriter-knop (server-side)
ANTHROPIC_API_KEY=sk-ant-...
